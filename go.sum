# 1. Перейдите в папку backend
cd backend

# 2. Удалите старые файлы (если есть)
rm -rf go.sum

# 3. Скачайте все зависимости и создайте go.sum
go mod tidy

# 4. Проверьте, что go.sum создался
ls -la | grep go.sum
# Должен быть файл

# 5. Закоммитьте и запушьте
git add go.sum
git commit -m "Add go.sum with dependencies"
git push

# 6. На Railway нажмите Redeploy
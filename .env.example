# App
PORT=8080
JWT_SECRET=replace-with-long-random-secret
CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app
DB_RETRY_INITIAL_DELAY=1s
DB_RETRY_INTERVAL=3s
DB_PING_TIMEOUT=5s

# PostgreSQL (Railway usually provides DATABASE_URL automatically)
DATABASE_URL=postgres://postgres:password@localhost:5432/lastop_db?sslmode=disable

{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && go mod download && go build -o main"
  },
  "deploy": {
    "startCommand": "cd backend && ./main",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "numReplicas": 1
  }
}